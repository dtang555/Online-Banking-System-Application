<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>FrontendService_tomcat</display-name>

    <servlet>
        <servlet-name>LoginEndpoint</servlet-name>
        <servlet-class>com.mycompany.frontendservice.endpoint.LoginEndpoint</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginEndpoint</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutEndpoint</servlet-name>
        <servlet-class>com.mycompany.frontendservice.endpoint.LogoutEndpoint</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutEndpoint</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>TransferEndpoint</servlet-name>
        <servlet-class>com.mycompany.frontendservice.endpoint.TransferEndpoint</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TransferEndpoint</servlet-name>
        <url-pattern>/transfer</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>BalanceEndpoint</servlet-name>
        <servlet-class>com.mycompany.frontendservice.endpoint.BalanceEndpoint</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BalanceEndpoint</servlet-name>
        <url-pattern>/balance</url-pattern>
    </servlet-mapping>

    <welcome-file-list>
        <welcome-file>login.html</welcome-file>
    </welcome-file-list>
</web-app>
